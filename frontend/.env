# === Environnement de DÉMO (fausses données, sans backend) ===
# Active le mode démo : démarre Mock Service Worker dans le navigateur
# et injecte un jeu de fausses données au démarrage.
VITE_DEMO_MODE=true

# Origine que les handlers MSW utilisent pour matcher les requêtes.
# Doit rester une URL absolue stable (les handlers font `${apiEndpoint}/...`).
# HTTPS (et pas HTTP) pour éviter le blocage "mixed content" sur le site déployé
# en HTTPS : aucune vraie connexion n'est tentée, MSW intercepte par URL.
VITE_API_URL=https://localhost:3001

# Feature flags (liste séparée par des virgules). Ajouter ici le flag de la
# fonctionnalité à tester quand elle sera intégrée.
VITE_FEATURE_FLAGS=

# BAN (Base Adresse Nationale) — intercepté par MSW de toute façon
VITE_BAN_URL=https://api-adresse.data.gouv.fr
VITE_BAN_ELIGIBLE_SCORE=0.8

# Metabase (optionnel — laissé vide)
VITE_METABASE_SITE_URL=
VITE_METABASE_STATS_DASHBOARD=

# PostHog analytics — désactivé en démo
VITE_POSTHOG_ENABLED=false
VITE_POSTHOG_API_KEY=

# Sentry error tracking — désactivé en démo
VITE_SENTRY_ENABLED=false
VITE_SENTRY_DSN=
VITE_SENTRY_ENV=demo
VITE_SENTRY_SAMPLE_RATE=0.2
VITE_SENTRY_TRACES_SAMPLE_RATE=0.2

VITE_APP_VERSION=demo

# File upload limits
VITE_FILE_UPLOAD_MAX_SIZE_MB=5
VITE_GEO_UPLOAD_MAX_SIZE_MB=100
VITE_PORT=3002
